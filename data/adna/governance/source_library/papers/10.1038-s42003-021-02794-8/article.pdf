            <a class="js-orcid" href="https://orcid.org/0000-0002-3138-1307"><span class="u-visually-hidden">ORCID: </span>orcid.org/0000-0002-3138-1307</a></span><sup class="u-js-hide"><a href="#Aff1">1</a></sup><sup class="u-js-hide"> <a href="#na2">na2</a></sup>, </li><li class="c-article-author-list__item c-article-author-list__item--hide c-article-author-list__item--hide-small-screen"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="41_42" data-track-context="researcher popup with no profile" href="#auth-_nci-Togan-Aff1" data-author-popup="auth-_nci-Togan-Aff1" data-author-search="Togan, İnci">İnci Togan</a><sup class="u-js-hide"><a href="#Aff1">1</a></sup><sup class="u-js-hide"> <a href="#na2">na2</a></sup> &amp; </li><li class="c-article-author-list__show-more" aria-label="Show all 42 authors for this article" title="Show all 42 authors for this article">…</li><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="42_42" data-track-context="researcher popup with no profile" href="#auth-F_sun-_zer-Aff14-Aff15" data-author-popup="auth-F_sun-_zer-Aff14-Aff15" data-author-search="Özer, Füsun" data-corresp-id="c2">Füsun Özer<svg width="16" height="16" focusable="false" role="img" aria-hidden="true" class="u-icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-eds-i-mail-medium"></use></svg></a><span class="u-js-hide"> 
